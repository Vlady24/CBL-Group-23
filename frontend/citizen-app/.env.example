# Citizen app environment variables
# Create a new file locally named '.env' in this folder.
# Copy the line below into it, and replace 'your_key_here' with your own Google Maps API key (no spaces, no quotes).
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Backend server URL
VITE_API_URL=http://localhost:8000
